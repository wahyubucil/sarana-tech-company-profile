---
import { Image } from 'astro:assets';
import imgBarong from '~/assets/images/barong.svg';
---

<div
  class="flex justify-center overflow-clip relative py-[78px] w-full bg-black"
  style={{ backgroundImage: "linear-gradient(264.72deg, rgb(22, 22, 22) 35.479%, rgb(3, 3, 3) 73.631%)" }}
>
  <div
    class="absolute h-[454px] w-[790px] left-0 top-[-72px] mix-blend-luminosity opacity-30 overflow-hidden pointer-events-none sm:left-auto sm:-right-1/2 md:right-[-160px] lg:right-[-130px] lg:top-[-100px]"
  >
    <Image
      alt=""
      class="w-full h-full object-cover mix-blend-color-dodge"
      src={imgBarong}
      loading="lazy"
    />
  </div>

  <div
    class="flex flex-col gap-[50px] items-start relative z-10 px-6 max-w-[1170px] w-full"
  >
    <p
      class="font-bold leading-[1.56] md:leading-[normal] text-[32px] md:text-[24px] text-white tracking-[1px] uppercase md:w-[635px]"
    >
      unlock the full potential of your business through DIGITAL
    </p>
    <a
      href="/contact"
      class="border border-solid border-white content-stretch flex items-start px-[30px] py-[14px] relative shrink-0 text-white hover:bg-white hover:text-black transition-all duration-300 ease-in-out"
    >
      <div
        class="flex flex-col font-normal justify-center leading-none relative shrink-0 text-[12px] text-center tracking-[1px] uppercase whitespace-nowrap"
      >
        <p class="leading-[17.143px] md:leading-[17px]">GET IN TOUCH</p>
      </div>
    </a>
  </div>
</div>
