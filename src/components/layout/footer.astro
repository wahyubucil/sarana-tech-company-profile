---
import { FaInstagram, FaLinkedinIn } from 'react-icons/fa6';

import { Logo } from './logo.tsx';
---

<footer
  class="relative flex w-full shrink-0 flex-col content-stretch items-center gap-[50px] overflow-clip bg-[#252525] py-[60px]"
>
  <div
    class="flex w-full max-w-[1170px] flex-col content-stretch items-start gap-[40px] px-6 md:flex-row md:gap-[150px] xl:px-0"
  >
    <div class="flex w-full flex-col gap-6 md:w-auto">
      <div class="h-[34px] w-[127px]"><Logo variant="light" /></div>
      <div class="text-[13px] leading-[24px] font-normal text-[#d8d8d8]">
        <p>SaranaTech (PT Sarana Digital Solusindo),</p>
        <p>{`We help realize the best potential of your `}</p>
        <p>{`business with coding & art from the land of Bali.`}</p>
      </div>
    </div>
    <div class="flex flex-col flex-wrap gap-[40px] md:flex-row md:gap-[150px]">
      <div class="order-3 flex flex-col gap-6 md:order-1">
        <p class="text-[16px] font-bold text-white uppercase">SITEMAP</p>
        <div
          class="flex flex-col text-[13px] leading-[32px] font-normal text-[#d8d8d8]"
        >
          <a
            href="/case-study"
            class="font-semibold transition-colors hover:text-white"
            >Case Study</a
          >
          <a
            href="/about"
            class="font-semibold transition-colors hover:text-white">About Us</a
          >
          <a
            href="/contact-us"
            class="font-bold transition-colors hover:text-white">Contact Us</a
          >
        </div>
      </div>
      <div class="order-2 flex flex-col gap-6">
        <p class="text-[16px] font-bold text-white uppercase">Contact Us</p>
        <div
          class="flex flex-col gap-2 text-[13px] leading-[24px] font-normal text-[#d8d8d8]"
        >
          <p class="font-bold">PT Sarana Digital Solusindo</p>
          <p>
            <span class="font-semibold">Office</span>
            : Perum. Raya Kampial No S11, Nusa Dua, Bali
          </p>
          <p>
            <span class="font-semibold">Whatsapp</span>
            :
            <a
              href="https://wa.me/6281338270676"
              target="_blank"
              rel="noopener noreferrer"
              class="underline hover:text-white">+62 813-3827-0676</a
            >
          </p>
          <p>
            <span class="font-bold">Email</span>
            :
            <a
              href="mailto:info@saranatech.id"
              class="underline hover:text-white">info@saranatech.id</a
            >
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="h-px w-full bg-[#444]"></div>

  <div
    class="flex w-full max-w-[1170px] flex-col items-center justify-between gap-4 px-6 md:flex-row xl:px-0"
  >
    <p class="text-center text-[13px] font-normal text-[#d8d8d8] md:text-left">
      © {new Date().getFullYear()} PT Sarana Digital Solusindo - All Rights Reserved.
    </p>
    <div class="flex gap-4">
      <a
        href="https://www.instagram.com/saranatech.id"
        target="_blank"
        rel="noopener noreferrer"
        class="text-white opacity-70 transition-opacity hover:opacity-100"
        aria-label="Instagram"><FaInstagram size={17} /></a
      >
      <a
        href="https://www.linkedin.com/company/sarana-tech/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-white opacity-70 transition-opacity hover:opacity-100"
        aria-label="LinkedIn"><FaLinkedinIn size={17} /></a
      >
    </div>
  </div>
</footer>
