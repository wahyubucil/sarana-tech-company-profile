---
import { Logo } from '~/components/logo.tsx';
import { Navigation } from '~/components/navigation.tsx';
---

<header
  class="h-[86px] flex items-center justify-between w-full max-w-[1170px] mx-auto px-4 xl:px-0"
>
  <div class="relative h-[34px] w-[127px] shrink-0">
    <a
      href="/"
      class="relative z-30 block size-full"
      aria-label="SaranaTech Logo"
    >
      <Logo variant="dark" />
    </a>
  </div>

  <!-- Desktop Navigation -->
  <nav
    class="hidden md:flex content-stretch font-semibold gap-[35px] items-center leading-none py-[12px] text-[12px] uppercase whitespace-nowrap"
  >
    <div class="flex flex-col justify-center relative shrink-0 text-[#727272]">
      <a
        href="/"
        class="leading-[20px] transition-colors duration-300 ease-in-out hover:text-[#101010]"
        >HOME</a
      >
    </div>
    <div
      class="flex flex-col justify-center relative shrink-0 text-[#101010] cursor-pointer"
    >
      <a
        href="#services"
        class="leading-[20px] transition-colors duration-300 ease-in-out hover:text-[#727272]"
        >services</a
      >
    </div>
    <div
      class="flex flex-col justify-center relative shrink-0 text-[#101010] cursor-pointer"
    >
      <a
        href="/case-study"
        class="leading-[20px] transition-colors duration-300 ease-in-out hover:text-[#727272]"
        >Case study</a
      >
    </div>
    <div
      class="flex flex-col justify-center relative shrink-0 text-[#101010] cursor-pointer"
    >
      <a
        href="#1000dev"
        class="leading-[20px] transition-colors duration-300 ease-in-out hover:text-[#727272]"
        >#1000Dev</a
      >
    </div>
    <div
      class="flex flex-col justify-center relative shrink-0 text-[#101010] cursor-pointer"
    >
      <a
        href="/contact"
        class="leading-[20px] transition-colors duration-300 ease-in-out hover:text-[#727272]"
        >contact us</a
      >
    </div>
  </nav>

  <!-- Mobile Navigation (Hamburger) -->
  <Navigation client:load />
</header>
