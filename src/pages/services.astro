---
import { Image } from 'astro:assets';

import {
  Mobile,
  MonitorMobbile,
  ProgrammingArrows,
  RulerPen,
  Shop,
  StatusUp,
} from 'iconsax-react';

import Layout from '~/layouts/Layout.astro';

import imgHeroServices from '~/assets/images/services/hero.jpg';
import imgTms from '~/assets/images/services/tms.jpg';
import imgTracking from '~/assets/images/services/tracking.jpg';

const services = [
  {
    icon: RulerPen,
    title: 'Web designing',
    description:
      'Create visually captivating and user-friendly websites that effectively communicate brand messages, and deliver a positive UX.',
  },
  {
    icon: MonitorMobbile,
    title: 'Web development',
    description:
      'Web development brings ideas to life, crafting functional and interactive websites through coding and programming.',
  },
  {
    icon: Mobile,
    title: 'MOBILE APPS DEVELOPMENT',
    description:
      'Innovative, user-centric solutions for iOS and Android. Seamlessly blend functionality and aesthetics to captivate users on the go.',
  },
  {
    icon: StatusUp,
    title: 'SYSTEM DEVELOPMENT',
    description:
      'Efficient creation of customized software systems to optimize processes, enhance productivity, and drive business growth.',
  },
  {
    icon: Shop,
    title: 'ecommerce',
    description:
      'Enabling businesses to sell products/services, manage inventory, process transactions, and provide a seamless shopping experience.',
  },
  {
    icon: ProgrammingArrows,
    title: 'ERP / AUTOMATION',
    description:
      'Streamline operations and boost productivity with ERP automation, the key to efficient business processes.',
  },
];

const products = [
  {
    image: imgTracking,
    title: 'NEXUS EDU-FINANCE',
    description:
      'Efficient tracking & management of drivers. Businesses can seamlessly monitor & optimize their fleet operations, enhancing productivity, & cost effectiveness.',
  },
  {
    image: imgTracking,
    title: 'XARANA TRACKING',
    description:
      'Efficient tracking & management of drivers. Businesses can seamlessly monitor & optimize their fleet operations, enhancing productivity, & cost effectiveness.',
  },
  {
    image: imgTms,
    title: 'TRANSPORT MANAGEMENT SYSTEM',
    description:
      'Optimize delivery schedules, monitor vehicle performance, and enhance overall efficiency. Simplify transportation processes & improve cust satisfaction.',
  },
];
---

<Layout
  title="Services | SaranaTech"
  description="Discover our wide range of digital services, including web design, web development, mobile apps, and system development."
>
  <div
    class="relative flex h-[380px] w-full flex-col items-center justify-center overflow-hidden"
  >
    <div class="pointer-events-none absolute inset-0">
      <Image
        src={imgHeroServices}
        alt="Our Services"
        class="h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-[#343434]/20"></div>
    </div>
    <h1
      class="relative text-center text-[32px] leading-[44px] font-semibold tracking-[6px] text-white uppercase md:text-[40px]"
    >
      OUR SERVICES
    </h1>
  </div>

  <section class="bg-[#fbfbfb] px-6 py-16 lg:py-[100px]">
    <div
      class="container mx-auto flex max-w-[1170px] flex-col items-center gap-[60px]"
    >
      <div class="flex max-w-[855px] flex-col items-center gap-5 text-center">
        <h2
          class="text-[26px] leading-[28.6px] font-bold tracking-[1px] text-[#101010] uppercase"
        >
          services what we provide
        </h2>
        <p class="text-[15px] leading-[28px] font-normal text-[#767676]">
          With our deep expertise in the latest technologies and industry best
          practices, we empower businesses to stay ahead in the digital
          landscape.
        </p>
      </div>

      <div
        class="grid w-full grid-cols-1 gap-x-[45px] gap-y-[60px] md:grid-cols-2 lg:grid-cols-3"
      >
        {
          services.map((service) => (
            // biome-ignore lint/correctness/useJsxKeyInIterable: Astro static arrays do not require keys
            <div class="flex flex-col items-start">
              <service.icon
                size="35"
                color="#101010"
                variant="Linear"
                className="mb-8"
              />
              <h3 class="mb-4 text-[14px] font-normal tracking-[2px] text-[#101010] uppercase">
                {service.title}
              </h3>
              <div class="mb-6 h-[2px] w-[38px] bg-[#333]" />
              <p class="text-[14px] leading-[28px] tracking-[0.5px] text-[#767676]">
                {service.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-white px-6 py-16 lg:py-[100px]">
    <div
      class="container mx-auto flex max-w-[1170px] flex-col items-center gap-[70px]"
    >
      <div class="flex max-w-[855px] flex-col items-center gap-5 text-center">
        <h2
          class="text-[26px] leading-[28.6px] font-bold tracking-[1px] text-[#101010] uppercase"
        >
          Our software product
        </h2>
        <p class="text-[15px] leading-[28px] font-normal text-[#767676]">
          Powerful solution designed to streamline operations, enhance
          productivity, and drive business growth. Experience the transformative
          capabilities and unlock your full potential with our cutting-edge
          software.
        </p>
      </div>

      <div
        class="grid w-full grid-cols-1 gap-[50px] sm:justify-center md:justify-center lg:grid-cols-3"
      >
        {
          products.map((product) => (
            // biome-ignore lint/correctness/useJsxKeyInIterable: Astro static arrays do not require keys
            <div class="flex flex-col items-start sm:mx-auto sm:w-[480px] md:mx-auto md:w-[480px] lg:mx-0 lg:w-full">
              <div class="relative mb-[14px] aspect-360/250 w-full overflow-hidden bg-gray-100">
                <Image
                  src={product.image}
                  alt={product.title}
                  class="absolute inset-0 h-full w-full object-cover"
                />
              </div>
              <h3 class="mb-[14px] text-[16px] font-semibold tracking-[1px] text-[#101010] uppercase">
                {product.title}
              </h3>
              <p class="text-[13px] leading-[28px] text-[#767676]">
                {product.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
