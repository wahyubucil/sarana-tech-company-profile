---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

import { caseStudiesData, type CaseStudyData } from '~/data/case-studies';
import Layout from '~/layouts/Layout.astro';

export function getStaticPaths() {
  return caseStudiesData.map((study) => ({
    params: { id: study.id },
    props: { study },
  }));
}

interface Props {
  study: CaseStudyData;
}

const { study } = Astro.props;

// Formatting line breaks properly
const formatParagraphs = (text: string) =>
  text.split('\n').filter((p) => p.trim() !== '');

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/case-study/*.{jpeg,jpg,png,gif}',
);

const heroImagePath = `/src/assets/images/case-study/${study.heroImage}`;
if (!images[heroImagePath])
  throw new Error(`"${heroImagePath}" does not exist in glob`);
---

<Layout
  title={`${study.title} - Case Study`}
  description={`Discover our work for ${study.client}: ${study.jobdesc}`}
>
  <!-- Main Content Wrapper -->
  <main class="flex w-full flex-col items-center pb-20 md:pb-[100px]">
    <!-- Title & Meta Information Section -->
    <section
      class="mx-auto flex w-full max-w-[1170px] flex-col gap-[50px] px-6 pt-[60px] pb-[60px]"
    >
      <h1
        class="max-w-[640px] text-[32px] leading-tight font-bold text-[#101010] md:text-[40px]"
      >
        {study.title}
      </h1>

      <div class="flex flex-col gap-8 md:flex-row md:gap-10">
        <!-- Client -->
        <div class="flex w-full flex-col md:w-[134px]">
          <span class="text-[15px] leading-[28px] font-normal text-[#101010]"
            >Client:</span
          >
          <span class="text-[15px] leading-[28px] font-normal text-[#767676]"
            >{study.client}</span
          >
        </div>

        <!-- Jobdesc -->
        <div class="flex w-full flex-col md:max-w-[371px]">
          <span class="text-[15px] leading-[28px] font-normal text-[#101010]"
            >Jobdesc:</span
          >
          <span class="text-[15px] leading-[28px] font-normal text-[#767676]"
            >{study.jobdesc}</span
          >
        </div>

        <!-- Year -->
        <div class="flex w-full flex-col md:w-[62px]">
          <span class="text-[15px] leading-[28px] font-normal text-[#101010]"
            >Year:</span
          >
          <span class="text-[15px] leading-[28px] font-normal text-[#767676]"
            >{study.year}</span
          >
        </div>
      </div>
    </section>

    <!-- Hero Image -->
    <section class="mx-auto mb-[100px] w-full max-w-[1170px] px-6">
      <div
        class="relative aspect-1170/380 w-full overflow-hidden rounded-lg bg-[#E7E7E7]"
      >
        <Image
          src={images[heroImagePath]()}
          alt={study.title}
          class="h-full w-full object-cover"
        />
      </div>
    </section>

    <!-- Content Sections -->
    <section
      class="mx-auto flex w-full max-w-[1170px] flex-col items-center px-6"
    >
      <div class="flex w-full flex-col gap-[50px]">
        <!-- About -->
        <div class="flex w-full max-w-[640px] flex-col gap-5">
          <h2 class="text-[20px] leading-[29px] font-bold text-[#101010]">
            {study.aboutTitle}
          </h2>
          <div class="flex flex-col gap-4">
            {
              formatParagraphs(study.aboutDesc).map((p) => (
                // biome-ignore lint/correctness/useJsxKeyInIterable: intentional
                <p class="text-[15px] leading-[28px] font-normal text-[#767676]">
                  {p}
                </p>
              ))
            }
          </div>
        </div>

        <!-- Challenges -->
        <div class="flex w-full max-w-[640px] flex-col gap-5">
          <h2 class="text-[20px] leading-[29px] font-bold text-[#101010]">
            Challenges:
          </h2>
          <ul class="flex list-disc flex-col gap-2 pl-5">
            {
              formatParagraphs(study.challenges).map((p) => (
                // biome-ignore lint/correctness/useJsxKeyInIterable: intentional
                <li class="text-[15px] leading-[28px] font-normal text-[#767676]">
                  {p}
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Solutions -->
        <div class="flex w-full max-w-[640px] flex-col gap-5">
          <h2 class="text-[20px] leading-[29px] font-bold text-[#101010]">
            Solutions:
          </h2>
          <ul class="flex list-disc flex-col gap-2 pl-5">
            {
              formatParagraphs(study.solutions).map((p) => (
                // biome-ignore lint/correctness/useJsxKeyInIterable: intentional
                <li class="text-[15px] leading-[28px] font-normal text-[#767676]">
                  {p}
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Tech Stack -->
        <div class="flex w-full max-w-[640px] flex-col gap-5">
          <h2 class="text-[20px] leading-[29px] font-bold text-[#101010]">
            Tech stack:
          </h2>
          <div class="flex flex-col gap-2">
            {
              formatParagraphs(study.techStack).map((p) => (
                // biome-ignore lint/correctness/useJsxKeyInIterable: intentional
                <p class="text-[15px] leading-[28px] font-normal text-[#767676]">
                  {p}
                </p>
              ))
            }
          </div>
        </div>

        <!-- Summary -->
        <div class="flex w-full max-w-[640px] flex-col gap-5">
          <h2 class="text-[20px] leading-[29px] font-bold text-[#101010]">
            Summary:
          </h2>
          <div class="flex flex-col gap-4">
            {
              formatParagraphs(study.summary).map((p) => (
                // biome-ignore lint/correctness/useJsxKeyInIterable: intentional
                <p class="text-[15px] leading-[28px] font-normal text-[#767676]">
                  {p}
                </p>
              ))
            }
          </div>
        </div>

        <!-- Content Images -->
        {
          study.contentImages.map((img) => {
            const contentImagePath = `/src/assets/images/case-study/${img}`;
            if (!images[contentImagePath])
              throw new Error(`"${contentImagePath}" does not exist in glob`);
            return (
              // biome-ignore lint/correctness/useJsxKeyInIterable: intentional
              <div class="flex aspect-1170/630 w-full items-center justify-center overflow-hidden rounded-lg bg-[#E7E7E7]">
                <Image
                  src={images[contentImagePath]()}
                  alt={`Showcase of ${study.title}`}
                  class="h-full w-full object-cover"
                />
              </div>
            );
          })
        }
      </div>
    </section>

    <!-- Other Case Study -->
    <section
      class="mx-auto mt-[100px] flex w-full max-w-[1170px] flex-col gap-[70px] px-6"
    >
      <h2 class="text-[40px] leading-tight font-bold text-[#101010]">
        Other Case Study
      </h2>
      <div class="hide-scrollbar w-full overflow-x-auto pb-4">
        <div class="flex min-w-max gap-[50px]">
          {
            caseStudiesData
              .filter((s) => s.id !== study.id)
              .map((other) => {
                const otherImagePath = `/src/assets/images/case-study/${other.heroImage}`;
                if (!images[otherImagePath])
                  throw new Error(`"${otherImagePath}" does not exist in glob`);
                return (
                  // biome-ignore lint/correctness/useJsxKeyInIterable: intentional
                  <a
                    href={`/case-studies/${other.id}`}
                    class="group flex w-[360px] cursor-pointer flex-col gap-4"
                  >
                    <div class="relative aspect-360/250 w-full overflow-hidden rounded-lg bg-[#F1F1F1]">
                      <Image
                        src={images[otherImagePath]()}
                        alt={other.title}
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      />
                    </div>
                    <div class="w-fit rounded-full bg-[#F1F1F1] px-5 py-2.5 transition-colors duration-300 group-hover:bg-gray-200">
                      <span class="text-[10px] font-bold tracking-[1px] text-[#101010] uppercase">
                        Website
                      </span>
                    </div>
                    <h3 class="text-[16px] font-bold tracking-[1px] text-[#101010] uppercase transition-colors duration-300 group-hover:text-[#12A60F]">
                      {other.client}
                    </h3>
                    <p class="line-clamp-3 text-[13px] leading-[28px] font-normal text-[#767676]">
                      {other.aboutDesc.substring(0, 150)}...
                    </p>
                  </a>
                );
              })
          }
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
