---
import Layout from '~/layouts/Layout.astro';
---

<Layout title="Contact Us | SaranaTech" hideCta={true}>
  <main class="flex w-full flex-col items-center">
    <section
      class="mx-auto w-full max-w-[1170px] px-4 py-10 md:py-[60px] xl:px-0"
    >
      <h1
        class="max-w-[570px] text-[32px] leading-[48px] font-bold tracking-[1px] md:text-[40px] md:leading-[60px]"
      >
        Reach Out to Us for Further Inquiries and Collaboration Opportunities
      </h1>
    </section>

    <section
      class="mx-auto w-full max-w-[1170px] px-4 pb-20 md:pb-[100px] xl:px-0"
    >
      <div
        class="flex w-full flex-col items-start gap-[40px] md:flex-row md:gap-[30px]"
      >
        <!-- Left Column -->
        <div
          class="flex max-w-[570px] flex-1 flex-col gap-[40px] text-[15px] leading-[28px] text-[#767676]"
        >
          <p>
            We value your feedback and look forward to building productive
            relationships with individuals and organizations alike. Contact us
            today and let's explore how we can work together to achieve your
            goals.
          </p>
          <div>
            <p class="mb-1 font-bold">PT Sarana Digital Solusindo</p>
            <p class="mb-1 text-[#767676]">
              <span class="font-semibold">Office</span>
              : Perum. Raya Kampial No S11, Nusa Dua, Bali
            </p>
            <p class="mb-1 text-[#767676]">
              <span class="font-semibold">Whatsapp</span>
              :
              <a
                href="https://wa.me/6281338270676"
                class="underline transition-colors hover:text-[#101010]"
                >+62 813-3827-0676</a
              >
            </p>
            <p class="text-[#767676]">
              <span class="font-bold">Email</span>
              :
              <a
                href="mailto:info@saranatech.id"
                class="underline transition-colors hover:text-[#101010]"
                >info@saranatech.id</a
              >
            </p>
          </div>
        </div>

        <!-- Right Column (Form) -->
        <div class="flex w-full flex-1 flex-col gap-[24px]">
          <div class="flex flex-col gap-[6px]">
            <label for="name" class="text-[14px] font-medium">Your name</label>
            <input
              type="text"
              id="name"
              placeholder="Type your name here"
              class="w-full border border-[#c7c9d9] bg-white px-[16px] py-[10px] text-[14px] transition-colors outline-none placeholder:text-[#767676] focus:border-[#101010]"
            />
          </div>

          <div class="flex flex-col gap-[6px]">
            <label for="company" class="text-[14px] font-medium"
              >Company name</label
            >
            <input
              type="text"
              id="company"
              placeholder="Type your company name here"
              class="w-full border border-[#c7c9d9] bg-white px-[16px] py-[10px] text-[14px] transition-colors outline-none placeholder:text-[#767676] focus:border-[#101010]"
            />
          </div>

          <div class="flex flex-col gap-[6px]">
            <label for="email" class="text-[14px] font-medium">Your email</label
            >
            <input
              type="email"
              id="email"
              placeholder="Type your email here"
              class="w-full border border-[#c7c9d9] bg-white px-[16px] py-[10px] text-[14px] transition-colors outline-none placeholder:text-[#767676] focus:border-[#101010]"
            />
          </div>

          <div class="flex flex-col gap-[6px]">
            <label for="topic" class="text-[14px] font-medium"
              >Topic of discussion</label
            >
            <div class="relative w-full">
              <select
                id="topic"
                class="w-full cursor-pointer appearance-none border border-[#c7c9d9] bg-white px-[16px] py-[10px] text-[14px] transition-colors outline-none focus:border-[#101010]"
              >
                <option value="projects">About projects</option>
                <option value="careers">Careers</option>
                <option value="partnerships">Partnerships</option>
                <option value="other">Other</option>
              </select>
              <div
                class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4"
              >
                <svg
                  width="12"
                  height="8"
                  viewBox="0 0 12 8"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <path
                    d="M1 1.5L6 6.5L11 1.5"
                    stroke="#555770"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </div>
            </div>
          </div>

          <div class="flex flex-col gap-[6px]">
            <label for="message" class="text-[14px] font-medium"
              >Your message</label
            >
            <textarea
              id="message"
              placeholder="Type your message here"
              rows="4"
              class="min-h-[108px] w-full resize-y border border-[#c7c9d9] bg-white px-[16px] py-[10px] text-[14px] transition-colors outline-none placeholder:text-[#767676] focus:border-[#101010]"
            ></textarea>
          </div>

          <button
            type="button"
            class="mt-2 w-full bg-[#15c912] px-[30px] py-[14px] text-[12px] font-bold tracking-[1px] text-white uppercase transition-colors duration-300 hover:bg-[#12b310]"
          >
            SEND MESSAGE
          </button>
        </div>
      </div>
    </section>
  </main>
</Layout>
