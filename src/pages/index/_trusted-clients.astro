---
import imgEcoBeachCity from '~/assets/images/clients/eco-beach-city.png';
import imgPawiba from '~/assets/images/clients/pawiba.png';
import imgSunMotor from '~/assets/images/clients/sun-motor.png';
import imgSunRental from '~/assets/images/clients/sun-rental.png';
import imgUxdIsland from '~/assets/images/clients/uxd-island.png';
import imgWebfeeling from '~/assets/images/clients/webfeeling.png';
---

<div class="bg-[#fbfbfb] py-[100px] overflow-clip relative shrink-0 w-full">
  <div
    class="relative shrink-0 w-full max-w-[1170px] mx-auto px-4 md:px-0 flex flex-col items-center"
  >
    <div class="flex flex-col items-center gap-4 mb-[70px]">
      <p
        class="font-bold text-[#101010] text-[26px] text-center tracking-[1px] uppercase"
      >
        our trusted clients
      </p>
      <p
        class="font-normal leading-[28px] text-[#989898] text-[15px] text-center max-w-[831px]"
      >
        Our clients appreciate the collaborative approach we take, as we work
        closely with them to gain a deep understanding of their unique
        requirements and goals.
      </p>
    </div>
    <div
      class="grid grid-cols-2 md:grid-cols-3 w-full border-t border-l border-[#e5e5e5]"
    >
      <div
        class="border-b border-r border-[#e5e5e5] h-[221px] flex items-center justify-center p-8"
      >
        <img
          alt="SUN Motor"
          class="max-w-[150px] max-h-[150px] object-contain"
          src={imgSunMotor.src}
        >
      </div>
      <div
        class="border-b border-r border-[#e5e5e5] h-[221px] flex items-center justify-center p-8"
      >
        <img
          alt="SUN Rental"
          class="max-w-[150px] max-h-[150px] object-contain"
          src={imgSunRental.src}
        >
      </div>
      <div
        class="border-b border-r border-[#e5e5e5] h-[221px] flex items-center justify-center p-8"
      >
        <img
          alt="UXD Island"
          class="max-w-[150px] max-h-[150px] object-contain"
          src={imgUxdIsland.src}
        >
      </div>
      <div
        class="border-b md:border-b-0 border-r border-[#e5e5e5] h-[221px] flex items-center justify-center p-8"
      >
        <img
          alt="Eco Beach City"
          class="max-w-[150px] max-h-[150px] object-contain"
          src={imgEcoBeachCity.src}
        >
      </div>
      <div
        class="border-b md:border-b-0 border-r border-[#e5e5e5] h-[221px] flex items-center justify-center p-8"
      >
        <img
          alt="Webfeeling"
          class="max-w-[150px] max-h-[150px] object-contain"
          src={imgWebfeeling.src}
        >
      </div>
      <div
        class="border-b md:border-b-0 border-r border-[#e5e5e5] h-[221px] flex items-center justify-center p-8"
      >
        <img
          alt="Pawiba"
          class="max-w-[150px] max-h-[150px] object-contain"
          src={imgPawiba.src}
        >
      </div>
    </div>
  </div>
</div>
