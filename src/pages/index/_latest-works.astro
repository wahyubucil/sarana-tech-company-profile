---
import imgMobileAppMockup from '~/assets/images/works/mobile-app-mockup.png';
import imgEcoBeachCityMap from '~/assets/images/works/eco-beach-city-map.png';
import imgWebAppMockup from '~/assets/images/works/web-app-mockup.png';
import imgDashboardMockup from '~/assets/images/works/dashboard-mockup.png';
---

<div
  class="content-stretch flex flex-col gap-[35px] items-center overflow-clip px-4 md:px-[50px] py-[100px] relative shrink-0 w-full max-w-[1440px]"
>
  <div class="flex flex-col items-center gap-4 mb-8">
    <p
      class="font-bold text-[#101010] text-[26px] text-center tracking-[1px] uppercase"
    >
      our latest works
    </p>
    <p
      class="font-normal leading-[28px] text-[#989898] text-[15px] text-center max-w-[831px]"
    >
      We offer a wide range of services, including web development, mobile app
      development, custom software development, and UI/UX design.
    </p>
  </div>
  <div
    class="content-stretch flex flex-col md:flex-row gap-[10px] items-center md:items-start overflow-clip relative shrink-0 w-full justify-center"
  >
    <div
      class="bg-[#f3f3f3] h-[230px] overflow-hidden relative shrink-0 w-full md:w-[277px] group cursor-pointer"
    >
      <div class="absolute inset-0 flex items-center justify-center p-4">
        <img
          alt="Eco Beach City"
          class="max-w-full max-h-full object-contain"
          src={imgEcoBeachCityMap.src}
        >
      </div>
      <div
        class="absolute inset-0 bg-[#f1f1f1] opacity-0 group-hover:opacity-90 transition-opacity flex flex-col items-center justify-center"
      >
        <p class="font-bold text-[#101010] text-[15px]">
          Interactive Map & Booking
        </p>
        <p class="font-normal text-[#101010] text-[10px] mt-1">
          Eco Beach City
        </p>
      </div>
    </div>
    <div
      class="bg-[#f3f3f3] h-[230px] overflow-hidden relative shrink-0 w-full md:w-[277px] group cursor-pointer"
    >
      <div class="absolute inset-0 flex items-center justify-center p-4">
        <img
          alt="Mobile App"
          class="max-w-full max-h-[120%] object-cover object-top"
          src={imgMobileAppMockup.src}
        >
      </div>
    </div>
    <div
      class="bg-[#f3f3f3] h-[230px] overflow-hidden relative shrink-0 w-full md:w-[277px] group cursor-pointer"
    >
      <div class="absolute inset-0 flex items-center justify-center">
        <img
          alt="Web Application"
          class="max-w-[120%] max-h-[120%] object-cover"
          src={imgWebAppMockup.src}
        >
      </div>
    </div>
    <div
      class="bg-[#f3f3f3] h-[230px] overflow-hidden relative shrink-0 w-full md:w-[277px] group cursor-pointer"
    >
      <div class="absolute inset-0 flex items-center justify-center p-4">
        <img
          alt="Dashboard"
          class="max-w-full max-h-full object-contain"
          src={imgDashboardMockup.src}
        >
      </div>
    </div>
  </div>
</div>
